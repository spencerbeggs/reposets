{
	"version": "1.0.0",
	"project": {
		"name": "spencerbeggs/reposets",
		"type": "monorepo",
		"repository": "https://github.com/spencerbeggs/reposets",
		"maintainer": "C. Spencer Beggs"
	},
	"paths": {
		"designDocs": ".claude/design",
		"skills": ".claude/skills",
		"context": "CLAUDE.md"
	},
	"modules": {
		"reposets": {
			"path": "package",
			"designDocsPath": ".claude/design/reposets",
			"categories": ["architecture", "other"],
			"maintainer": "C. Spencer Beggs"
		}
	},
	"skills": {
		"baseNamespace": "/",
		"enabled": [
			"design-init",
			"design-validate",
			"design-update",
			"design-sync",
			"design-review",
			"design-audit",
			"design-search",
			"design-report"
		]
	},
	"quality": {
		"designDocs": {
			"maxLineLength": 120,
			"requireFrontmatter": true,
			"requireTOC": false,
			"minSections": ["Overview"]
		}
	},
	"integration": {
		"ci": {
			"enabled": false,
			"validateOnPR": false,
			"syncOnMerge": false
		},
		"git": {
			"trackDesignDocs": true,
			"requireReviewForChanges": false
		}
	}
}
