{
	"name": "reposets",
	"version": "0.4.2",
	"description": "CLI tool to sync GitHub repo settings, secrets and rulesets across personal repositories",
	"keywords": [
		"github",
		"sync",
		"cli",
		"secrets",
		"rulesets",
		"variables",
		"environments",
		"toml",
		"effect",
		"xdg",
		"repository",
		"settings",
		"automation",
		"devops"
	],
	"homepage": "https://github.com/spencerbeggs/reposets#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/reposets/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/reposets.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"reposets": "./src/cli/index.ts"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"generate:json-schema": "tsx lib/scripts/generate-json-schema.ts",
		"prepare": "node savvy.build.ts --target dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@1password/sdk": "^0.4.0",
		"@effect/cli": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@octokit/rest": "^22.0.1",
		"blakejs": "^1.2.1",
		"effect": "catalog:silk",
		"smol-toml": ">=1.6.1",
		"tweetnacl": "^1.0.3",
		"xdg-effect": "^1.0.3"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.6.1",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"tsx": "catalog:silk",
		"typescript": "catalog:silk"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/npm",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/reposets"
		}
	}
}
