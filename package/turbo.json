{
	"extends": ["//"],
	"tasks": {
		"build:dev": {
			"dependsOn": ["$TURBO_EXTENDS$", "generate:json-schema"]
		},
		"build:prod": {
			"dependsOn": ["$TURBO_EXTENDS$", "generate:json-schema"]
		},
		"generate:json-schema": {
			"cache": true,
			"inputs": ["src/schemas/**", "lib/scripts/generate-json-schema.ts"],
			"outputs": ["schemas/**"]
		}
	}
}
